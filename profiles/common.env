# ─── profiles/common.env ───────────────────────────────────────────────────────
# THE single source of truth for the llama.cpp vision-server tuning that is
# IDENTICAL on every machine (cosmic, cosmos, any future box). Both launchers —
# scripts/llamacpp_server.sh (Linux) and scripts/cosmic/serve_vision.cmd (Windows)
# — read these. Change a shared knob HERE, once.
#
# What VARIES per machine (GPU backend, parallel slots, lib path, host) is NOT
# here — it lives in profiles/<machine>.env. See docs/reference/multi-machine-setup.md.
#
# Plain KEY=value, no quotes/spaces, so bash (`. file`) and cmd (`for /f`) both read it.
# ───────────────────────────────────────────────────────────────────────────────
LLAMACPP_MODEL=qwen2.5vl:7b
LLAMACPP_PORT=18082
LLAMACPP_CTX_PER_SLOT=8192
LLAMACPP_NGL=99
LLAMACPP_FLASH=on
LLAMACPP_BATCH=2048
LLAMACPP_UBATCH=2048
