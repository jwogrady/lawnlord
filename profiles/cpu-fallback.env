# ─── profile: cpu-fallback ─────────────────────────────────────────────────────
# No GPU assumptions. For any machine without a working GPU backend (or for
# debugging the pipeline without inference). Local vision will be slow on CPU;
# prefer the cloud backend if ANTHROPIC_API_KEY is set.
#
# ACTIVATE:  cp profiles/cpu-fallback.env .env   (then append ANTHROPIC_API_KEY=...)
# ───────────────────────────────────────────────────────────────────────────────

# Probe localhost only; if no Ollama answers, the local backend no-ops with a reason.
OLLAMA_HOSTS="http://localhost:11434"

# Single primary model; keep the corpus minimal on CPU.
LAWNLORD_MODELS="qwen2.5vl:7b"

# CPU vision serializes anyway.
LAWNLORD_WORKERS=1
