# ─── profile: cosmos-nvidia ────────────────────────────────────────────────────
# Home workstation. NVIDIA GPU, native Linux. A local Linux Ollama serves the GPU
# directly (no host-offload hop). This matches the committed script defaults.
#
# ACTIVATE:  cp profiles/cosmos-nvidia.env .env   (then append ANTHROPIC_API_KEY=...)
#
# TODO(verify-at-home): the values below are the expected localhost defaults. Run
# the cosmos check-in checklist in docs/reference/multi-machine-setup.md and
# confirm/replace each value, then fill docs/reference/development-machine-cosmos.md.
# ───────────────────────────────────────────────────────────────────────────────

# Local Linux Ollama serves the NVIDIA GPU directly.
OLLAMA_HOSTS="http://localhost:11434"

# Both vision models are installed on cosmos (qwen primary + minicpm comparison).
LAWNLORD_MODELS="qwen2.5vl:7b minicpm-v:latest"

# Workers. Server runs NUM_PARALLEL=1 by default, so 1; raise only if Ollama is
# launched with a matching NUM_PARALLEL.
LAWNLORD_WORKERS=1

# llamacpp_server.sh (Linux/CUDA vision server) paths — confirm at home:
# OLLAMA_LIB=/usr/local/lib/ollama   # Ollama's bundled llama-server + CUDA libs
# MODEL=qwen2.5vl:7b
# PORT=18082
# CTX=8192
