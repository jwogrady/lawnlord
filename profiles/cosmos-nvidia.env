# ─── profile: cosmos-nvidia ────────────────────────────────────────────────────
# ✅ llama.cpp vision path VERIFIED ON REAL COSMOS HARDWARE (2026-06-28) by an
#    end-to-end transcribe run of a 255-page court export. The Ollama-tier knobs
#    below (OLLAMA_HOSTS / LAWNLORD_MODELS) are still EXPECTED defaults — the
#    verified run used the llama.cpp backend, not Ollama.
#
# Machine: cosmos — NVIDIA GeForce RTX 3080 (10 GB), Ryzen 9 7900X, under WSL2
#   (Ubuntu) — NOT native Linux as earlier assumed. The WSL2 kernel string and
#   nvidia-smi's "No running processes found" (it can't enumerate processes
#   through the GPU paravirt layer) both confirm WSL2. nvidia-smi GPU-Util can
#   under-report under WSL2 — judge real load by power.draw.
#
# NOTE vs cosmic: the AMD box (cosmic, RX 6900 XT) has 16 GB; cosmos has only
#   10 GB. The cosmic production config (-np 4) peaks ~11 GB and does NOT fit
#   here. cosmos is the SMALLER card — size knobs do not transfer from cosmic.
#
# ACTIVATE:  cp profiles/cosmos-nvidia.env .env   (then append ANTHROPIC_API_KEY=...)
# ───────────────────────────────────────────────────────────────────────────────

# ── Ollama tier (EXPECTED — not the verified path) ──────────────────────────────
# Local Linux Ollama serves the NVIDIA GPU directly.
OLLAMA_HOSTS="http://localhost:11434"

# Vision models installed on cosmos (qwen = best/primary, minicpm = comparison).
LAWNLORD_MODELS="qwen2.5vl:7b minicpm-v:latest"

# ── llama.cpp vision server (VERIFIED path — scripts/llamacpp_server.sh) ─────────
# These drive scripts/llamacpp_server.sh and `lawnlord transcribe --backend llamacpp`.
OLLAMA_LIB=/usr/local/lib/ollama   # Ollama's bundled llama-server + CUDA libs (cuda_v13/cuda_v12)
MODEL=qwen2.5vl:7b                  # best model that fits 10 GB; bigger (e.g. 32b) won't
PORT=18082
CTX=8192                            # full context PER SLOT at NP=1 (see warning below)

# Parallel decode slots for the llama.cpp server.
# ⚠ Do NOT raise NP on the 10 GB RTX 3080 unless the context math is revalidated.
#   llama.cpp divides -c across parallel slots: at NP=2, -c 8192 gives only
#   4096 ctx/slot, which fails on a real ~4127-token page (4096 ctx error). NP=1
#   gives the full 8192/slot and uses LESS VRAM (one slot's buffers). Concurrent
#   prefills at NP>=2 would also OOM the ~350 MiB headroom on this card.
NP=1

# transcribe workers — match NP (single in-flight request -> single slot).
LAWNLORD_WORKERS=1

# ── Verified runtime numbers (cosmos, 2026-06-28, qwen2.5vl:7b @ 300 DPI) ────────
#   Backend          : llama.cpp (GPU mmproj, flash-attn, -b/-ub 2048), NP=1
#   VRAM             : ~8.7 GB stable after load; ~9.9 GB resident under active
#                      inference (of 10 GB total — ~350 MiB headroom, no OOM)
#   Clocks / power   : ~1890–1965 MHz SM, ~125–220 W (phase-dependent), ~58–61 C
#   Throughput       : ~6 s/page sequential (sparse pages; dense text decodes slower)
#   255-page runtime : ~25 min
#   Per-page prompt  : ~4050 image tokens + prompt + schema ≈ 4127 tokens
#
# FAILURE MODE THAT BIT US (record so it doesn't recur): a warmup with a SHORTER
# prompt landed ~4063 tokens — just under the 4096 NP=2 slot limit — so it passed
# and masked the bug. The real lawnlord prompt is 4127 tokens and failed all 255
# pages with HTTP 400 "exceeds context size" until NP was dropped to 1. Always
# validate context math with the actual transcribe prompt, not a toy warmup.
