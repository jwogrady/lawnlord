# ─── profile: cosmic-amd ───────────────────────────────────────────────────────
# Work workstation. AMD Radeon RX 6900 XT (RDNA2/gfx1030), Windows 11 + WSL2.
# Local inference runs on the Windows host via Vulkan (ROCm/HIP unsupported on this
# card). lawnlord runs in WSL and reaches the host over HTTP.
#
# ACTIVATE:  cp profiles/cosmic-amd.env .env   (then append ANTHROPIC_API_KEY=...)
# `.env` is gitignored; this template carries NO secrets.
#
# Full machine spec: docs/reference/development-machine.md
# ───────────────────────────────────────────────────────────────────────────────

# GPU inference lives on the Windows-host Ollama (the only one reachable from WSL).
# The local 5900X had MCE reboots under direct local inference, so we offload.
OLLAMA_HOST=http://172.31.128.1:11434

# Only qwen2.5vl is installed on the Windows host (minicpm-v is not).
LAWNLORD_MODELS=qwen2.5vl:7b

# Ollama (--backend local) workers. Requires the Windows-host Ollama launched with
# NUM_PARALLEL=6 to actually parallelize; otherwise extra workers queue behind 1 slot.
LAWNLORD_WORKERS=6

# ── PRODUCTION vision path is NOT this Ollama path ──
# The canonical, full-fidelity cosmic path is the standalone llama.cpp Vulkan
# server (native 300 DPI, ~24 pages/min). It is launched Windows-side and is not
# driven by these env vars:
#   Windows:  scripts/cosmic/serve_vision.cmd 4 2048
#   WSL:      lawnlord transcribe --backend llamacpp --workers 8 \
#               --llamacpp-host http://172.31.128.1:18082 --model qwen2.5vl:7b
# See docs/performance/native-300dpi-vulkan-benchmark.md and
#     docs/performance/cosmic-backend-comparison.md

# ── llama.cpp vision server: the ONLY knobs that differ from profiles/common.env ──
LLAMACPP_NP=4                 # 4 slots — sweep winner on the 16GB 6900XT (~24 pg/min)
LLAMACPP_BACKEND=vulkan       # gfx1030/RDNA2: Vulkan only (ROCm unsupported)
LLAMACPP_HOST=http://172.31.128.1:18082          # WSL -> Windows host
LLAMACPP_OLLAMA_LIB=C:\Users\john\AppData\Local\Programs\Ollama\lib\ollama
