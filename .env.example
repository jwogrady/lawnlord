# lawnlord environment — copy to `.env` and fill in. `.env` is gitignored; never commit secrets.

# --- Python CLI (src/lawnlord) ---

# Intake root. Resolution order: this var → lawnlord.toml [lawnlord] intake → ./intake.
# Point at the case archive repo's intake dir, e.g. ../gcp-hoa-case/intake
# LAWNLORD_INTAKE=../gcp-hoa-case/intake

# Enables `lawnlord transcribe` (Claude-vision page transcription). Cloud opt-in:
# transcribe no-ops unless this is set. Model defaults to claude-opus-4-8 (--model to override).
# ANTHROPIC_API_KEY=sk-ant-...

# --- Web viewer (web/, Bun) ---

# Built case dir the viewer reads (holds lawnlord.duckdb + intake/ + extracted/). Defaults to "."
# CASE_DIR=/path/to/case

# Port for the web viewer. Defaults to 4173.
# PORT=4173

# --- Local transcription scripts (scripts/transcribe_local.sh, llamacpp_server.sh) ---
# Machine-specific knobs are isolated in PER-MACHINE PROFILES (committed, no secrets)
# under profiles/. Pick yours instead of editing defaults into shared code:
#
#   cp profiles/cosmic-amd.env .env      # work box: AMD 6900XT, Windows-host Ollama
#   cp profiles/cosmos-nvidia.env .env   # home box: NVIDIA, local Linux Ollama
#   cp profiles/cpu-fallback.env .env    # no GPU
#
# Then append your secret to .env:  ANTHROPIC_API_KEY=sk-ant-...
# scripts/*.sh source .env at startup; .env wins over the committed script defaults.
# See docs/reference/multi-machine-setup.md for the full strategy.
#
# The knobs a profile sets (override any here too):
#   OLLAMA_HOST     — force one Ollama server (wins over OLLAMA_HOSTS)
#   OLLAMA_HOSTS    — space-separated probe list; first to answer /api/tags wins
#   LAWNLORD_MODELS — space-separated model-major corpus
#   LAWNLORD_WORKERS, LAWNLORD_BIN
#   MODEL/PORT/CTX/OLLAMA_LIB — llamacpp_server.sh (Linux/CUDA GPU vision server)
