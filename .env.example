# lawnlord environment — copy to `.env` and fill in. `.env` is gitignored; never commit secrets.

# --- Python CLI (src/lawnlord) ---

# Intake root. Resolution order: this var → lawnlord.toml [lawnlord] intake → ./intake.
# Point at the case archive repo's intake dir, e.g. ../gcp-hoa-case/intake
# LAWNLORD_INTAKE=../gcp-hoa-case/intake

# Enables `lawnlord transcribe` (Claude-vision page transcription). Cloud opt-in:
# transcribe no-ops unless this is set. Model defaults to claude-opus-4-8 (--model to override).
# ANTHROPIC_API_KEY=sk-ant-...

# --- Web viewer (web/, Bun) ---

# Built case dir the viewer reads (holds lawnlord.duckdb + intake/ + extracted/). Defaults to "."
# CASE_DIR=/path/to/case

# Port for the web viewer. Defaults to 4173.
# PORT=4173

# --- Local transcription scripts (scripts/transcribe_local.sh, llamacpp_server.sh) ---
# These scripts ship with the COSMOS profile baked in as defaults (the NVIDIA
# home box: a local Linux Ollama serving the RTX 3080 directly). Override any
# knob per-machine here; `.env` wins over the committed defaults.

# Ollama endpoint. OLLAMA_HOST forces one server; OLLAMA_HOSTS is a
# space-separated probe list (first to answer /api/tags wins). Cosmos serves
# locally (the default). On cosmic (AMD) GPU inference lives on the Windows host:
# OLLAMA_HOST=http://172.31.128.1:11434
# OLLAMA_HOSTS="http://172.31.128.1:11434 http://localhost:11434"

# Model-major sweep corpus (space-separated). Cosmos has both qwen + minicpm;
# a machine missing one narrows the list:
# LAWNLORD_MODELS="qwen2.5vl:7b minicpm-v:latest"

# Concurrent transcribe workers. Server runs NUM_PARALLEL=1, so 1.
# LAWNLORD_WORKERS=1

# lawnlord CLI binary (default .venv/bin/lawnlord).
# LAWNLORD_BIN=.venv/bin/lawnlord

# --- llamacpp_server.sh (GPU mmproj vision server; cosmos/Linux paths) ---
# MODEL=qwen2.5vl:7b
# PORT=18082
# CTX=8192
# OLLAMA_LIB=/usr/local/lib/ollama   # Ollama's bundled llama-server + CUDA libs
