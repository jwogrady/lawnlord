# Python
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Environments / build
.venv/
venv/
build/
dist/
*.egg-info/

# uv
# (uv.lock is committed; the environment is not)

# Local env — secrets (ANTHROPIC_API_KEY) never committed; .env.example is the template
.env
.env.local

# Local Claude Code state (settings, scheduled tasks, session memory) — never
# committed; memory lives in the user's ~/.claude, not the tool repo.
.claude/

# Case-specific intake materials never live in the tool repo — they belong in
# the case archive repo (e.g. ../gcp-hoa-case/intake/<provider>/). Tests use
# hermetic tmp_path fixtures, not committed case data.
intake/

# case-workspace config scaffolded by `lawnlord start` — belongs in a case repo, not here
lawnlord.toml

# Generated case artifacts when a command is run from the repo root (the derived,
# regenerable index + outputs). Case data and its derivatives never live here.
lawnlord.duckdb
compare/
artifacts/
knowledgebase/
extracted/
analysis/
outputs/
manifests/
